# Backend endpoints the frontend talks to. Copy to `.env` to override the
# localhost defaults baked into src/config.ts. In Docker these are set by
# docker-compose instead.
# VITE_WS_BASE_URL is a base (scheme + host, no path); the client appends
# /ws/rooms/{code} per room.
VITE_API_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
